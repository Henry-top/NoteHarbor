{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "墨岛笔记",
  "version": "0.1.1",
  "identifier": "com.noteharbor.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "墨岛笔记",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost data: blob: https:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "本地优先的 Markdown 个人笔记应用",
    "longDescription": "墨岛笔记是一款本地优先、兼容标准 Markdown 的个人笔记应用。",
    "copyright": "Copyright © 2026 NoteHarbor",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
